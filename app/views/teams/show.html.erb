<h1 class="text-3xl font-bold mb-6">Team Details</h1>

<div class="bg-white border rounded p-6 shadow-md max-w-xl mb-6">
  <h2 class="text-2xl font-semibold mb-2"><%= @team.name %></h2>
  <p class="text-gray-700 mb-4 whitespace-pre-wrap"><%= @team.about %></p>

  <div class="mt-4 space-x-2">
    <%= link_to 'Edit', edit_team_path(@team), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded" %>
    <%= link_to 'Back', teams_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded" %>
  </div>
</div>

<!-- Players Section -->
<h2 class="text-2xl font-bold mb-4">Players</h2>

<% @players = @team.players if @players.nil? %>
<!-- If we came from create action with errors, we'd already have @players -->

<% if @players.any? %>
  <% @players.each do |player| %>
    <div class="bg-white border rounded p-4 shadow-sm mb-3 flex items-center justify-between">
      <p class="text-gray-700 mr-4"><%= player.name %></p>
      <p class="text-gray-700 mr-4"><%= player.about %></p>
      <div class="flex space-x-2">
        <%= link_to 'Edit', edit_team_player_path(@team),
                    class: "bg-yellow-500 hover:bg-yellow-600 text-white px-2 py-1 rounded text-sm" %>
        <%= link_to 'Delete', team_player_path(@team, player),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "bg-red-500 hover:bg-red-600 text-white px-2 py-1 rounded text-sm" %>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="text-gray-500 mb-4">No players yet.</p>
<% end %>

<!-- Add a New Player Form -->
<div class="mt-4 bg-white border rounded p-4 shadow-md max-w-xl">
  <h3 class="text-xl font-bold mb-2">Add a Player</h3>

  <!-- Using `model: [@team, Player.new]` ensures the nested route is used automatically -->
  <%= form_with(model: [@team, Player.new], local: true) do |form| %>
    <% if @player && @player.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 p-3 rounded mb-3">
        <strong class="font-bold">
          <%= pluralize(@player.errors.count, "error") %> prevented saving:
        </strong>
        <ul class="list-disc list-inside">
          <% @player.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, "Player", class: "block font-semibold mb-1" %>
      <%= form.text_area :content, rows: 3,
            class: "border border-gray-300 rounded w-full p-2 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
    </div>

    <div class="mb-3">
      <%= form.label :about, "About The Player", class: "block font-semibold mb-1" %>
      <%= form.text_area :content, rows: 3,
            class: "border border-gray-300 rounded w-full p-2 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
    </div>

    <%= form.submit "Add Player",
          class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded" %>
  <% end %>
</div>